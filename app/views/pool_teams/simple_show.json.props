json.id @pool_team.id
json.team_name @pool_team.team_name
json.set! :total_score, @pool_team.total_score
json.pool_id @pool.id

json.owner do
  json.id @pool_team.owner.id
  json.name @pool_team.owner.name
end

json.current_team do
  json.array! @pool_team.current_team do |rp|
    player = rp.league_player
    summary = @player_summaries[rp.id]
    json.id rp.id
    json.league_player_id player.id
    json.name player.name
    json.added_at rp.added_at

    json.for_pool summary[:pool_score]
  end
end

json.previous_team do
  json.array! @pool_team.previous_team do |rp|
    player = rp.league_player
    summary = @player_summaries[rp.id]
    json.id rp.id
    json.league_player_id player.id
    json.name player.name
    json.added_at rp.added_at
    json.dropped_at rp.dropped_at

    json.for_pool summary[:pool_score]
  end
end
