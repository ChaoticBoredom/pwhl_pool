json.id @pool_team.id
json.team_name @pool_team.team_name
json.total_score @pool_team.total_score
json.pool_id @pool.id

json.owner do
	json.id @pool_team.owner.id
	json.name @pool_team.owner.name
end

json.current_team do
  json.array! @current_team do |tp|
    player = tp.league_player
    summary = @player_summaries[tp.id]
    
    json.id tp.id
    json.league_player_id player.id
    json.name player.name
    json.current_team_short_code player.current_team_short_code
    json.added_at tp.added_at

    json.scores do
      json.partial! partial: 'players/scores', locals: { summary: summary }
    end
  end
end

json.previous_team do
  json.array! @previous_team do |tp|
    player = tp.league_player
    summary = @player_summaries[tp.id]
    
    json.id tp.id
    json.league_player_id player.id
    json.name player.name
    json.current_team_short_code player.current_team_short_code
    json.added_at tp.added_at

    json.scores do
      json.partial! partial: 'players/scores', locals: { summary: summary }
    end
  end
end
