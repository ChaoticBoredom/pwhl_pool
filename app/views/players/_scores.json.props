json.pool_score summary[:pool_score]

json.scores do
  scores = summary[:scores]

  json.today scores[:today]
  json.yesterday scores[:yesterday]
  json.week_to_date scores[:week_to_date]
  json.month_to_date scores[:month_to_date]
  json.season_to_date scores[:season_to_date]
end

json.clipped_scores do
  clipped = summary[:clipped_scores]

  json.today clipped[:today]
  json.yesterday clipped[:yesterday]
  json.week_to_date clipped[:week_to_date]
  json.month_to_date clipped[:month_to_date]
  json.season_to_date clipped[:season_to_date]
end
