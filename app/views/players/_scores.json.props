cache_key = "json_scores/#{player.cache_key_with_version}/#{pool.id}/#{Date.current}"

json.today service.score_for_today(player)
json.history cache: cache_key do
  scores_hash = service.scores_summary(player)

  json.yesterday      scores_hash[:yesterday]
  json.week_to_date   scores_hash[:week_to_date]
  json.month_to_date  scores_hash[:month_to_date]
  json.season_to_date scores_hash[:season_to_date]
end
