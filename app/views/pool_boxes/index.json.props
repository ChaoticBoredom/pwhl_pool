json.boxes do
  json.array! @boxes do |box|
    json.id box.id
    json.name box.name

    json.players do
      json.array! box.players do |player|
        json.id player.id
        json.name player.name
        json.current_team_short_code player.current_team_short_code

        json.selected @selected_ids.include?(player.id)

        json.scores do
          json.partial! partial: 'players/scores_raw',
            locals: { summary: @player_summaries[player.id] }
        end
      end
    end
  end
end
