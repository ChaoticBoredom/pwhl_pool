json.using_reference_season @pool.using_reference_season?

json.boxes do
  json.array! @boxes do |box|
    json.id box.id
    json.name box.name
    json.order box.position

    json.players do
      json.array! box.players do |player|
        json.id player.id
        json.name player.name
        json.current_team_short_code player.current_team_short_code

        json.selected @selected_ids.include?(player.id)

        scores = @player_scores[player.id]

        json.scores do
          if @pool.using_reference_season?
            json.season_to_date scores || 0.0
          else
            json.partial! partial: 'players/scores_raw', locals: { summary: scores }
          end
        end
      end
    end
  end
end
